    {
      "description": "Command 누르는 동안 영어로 임시 전환",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                {
                  "language": "ko"
                }
              ]
            }
          ],
          "from": {
            "key_code": "left_command",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "select_input_source": {
                "language": "en"
              }
            },
            {
              "key_code": "left_command"
            }
          ],
          "to_after_key_up": [
            {
              "select_input_source": {
                "language": "ko"
              }
            }
          ]
        },
        {
